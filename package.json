{
  "name": "esbuild-obfuscator-plugin",
  "version": "1.0.0",
  "description": "JavaScript obfuscator plugin for esbuild",
  "keywords": [
    "esbuild",
    "javascript",
    "obfuscator",
    "obfuscator-plugin"
  ],
  "homepage": "https://github.com/shahradelahi/esbuild-obfuscator-plugin#readme",
  "bugs": {
    "url": "https://github.com/shahradelahi/esbuild-obfuscator-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/shahradelahi/esbuild-obfuscator-plugin.git"
  },
  "license": "MIT",
  "author": "Shahrad Elahi <shahrad@litehex.com> (https://github.com/shahradelahi)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**",
    "!dist/**/*.d.cts"
  ],
  "scripts": {
    "build": "tsup",
    "ci:publish": "changeset publish",
    "clean": "git clean -dfx node_modules dist .tsbuildinfo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm typecheck & eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "pnpm build && pnpm test && pnpm format:check && pnpm lint",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@shahrad/prettier-config",
  "dependencies": {
    "@se-oss/glob": "^1.0.0",
    "javascript-obfuscator": "^5.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@shahrad/eslint-config": "^1.1.0",
    "@shahrad/prettier-config": "^1.2.2",
    "@shahrad/tsconfig": "^1.3.0",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "esbuild": ">=0.14.0"
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
